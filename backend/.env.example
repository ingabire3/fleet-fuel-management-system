# ---- Server ----
NODE_ENV=development
PORT=4000
API_PREFIX=/api

# ---- Database ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fuel_fleet?schema=public"

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
OTP_TOKEN_SECRET=change-me-otp-secret

# ---- OTP ----
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
REQUIRE_LOGIN_OTP=false

# ---- SMTP (Email notifications) ----
# Leave SMTP_HOST empty to disable email sending (emails are logged and skipped).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=changeme
SMTP_FROM="Fleet Fuel <no-reply@example.com>"

# ---- Firebase Cloud Messaging (Push notifications) ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ---- CORS ----
# Comma-separated list of allowed origins, e.g. "https://your-app.vercel.app,https://your-domain.com".
# Use "*" only for local development.
CORS_ORIGIN=*

# ---- Public URLs (used in docs/landing page, not read by the server directly) ----
CLIENT_URL=https://your-app.vercel.app
API_URL=https://fuel-fleet-backend.onrender.com
